# ──────────────────────────────────────
# ContentPlanner — Environment Variables
# ──────────────────────────────────────
# Copy this to .env and fill in your values.
# Never commit .env to git.

# ── Supabase ──────────────────────────
# Get from: https://app.supabase.com/project/<ref>/settings/api
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOi...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...       # Worker only (keep secret)

# Frontend (Vite) — same values, exposed to the browser build
VITE_SUPABASE_URL=https://<project-ref>.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOi...

# ── Capture ───────────────────────────
# Capture is via the PWA share target (Add to Home Screen → Share → ContentPlanner).
# Telegram + Instagram-DM/Composio capture have been removed in favor of the PWA model.

# ── Anthropic — idea enrichment (capture-time summary) ──
# Get from: https://console.anthropic.com/keys
# Used by the Vercel /api/import enrichment (Claude Haiku). This path bills API credits.
# On the WORKER it also serves as the Tier-2 fallback for listening planning + synthesis
# if you don't set CLAUDE_CODE_OAUTH_TOKEN below.
ANTHROPIC_API_KEY=sk-ant-...

# ── OpenAI — embeddings (knowledgebase RAG) + idea/draft generation ──
# Get from: https://platform.openai.com/api-keys
# Required for the knowledgebase (M1): chunks are embedded with text-embedding-3-small.
# Also the primary generator for idea AI (Anthropic above is the fallback).
OPENAI_API_KEY=sk-...
# Embedding model for the knowledgebase. Must stay 1536-dim to match the schema.
EMBEDDING_MODEL=text-embedding-3-small

# ── Chrome extension (M3) — credentialed endpoints, pinned CORS ──
# The extension calls /api/extension/* with a Bearer token, so those endpoints
# pin CORS to the extension's origin instead of using a wildcard (security).
# Set this to chrome-extension://<your-extension-id> (find the id at
# chrome://extensions after loading the unpacked build). Comma-separate to allow
# both a dev and a published id.
EXTENSION_ORIGIN=

# ── Honcho — behavioral/voice memory (M5, deferred) ──
# Already stored in Supabase secrets; also add here so Vercel functions + the
# worker nightly job can reach it. Not on the generation hot path.
HONCHO_API_KEY=

# ── Listening planning + synthesis — billed to your Claude SUBSCRIPTION (not API credits) ──
# Generate locally with `claude setup-token` and paste into the Railway worker env.
# The worker runs query planning AND research-brief synthesis via the Claude CLI using this
# token, drawing from your Claude Pro/Max subscription quota instead of per-token API credits.
# REQUIRED on the worker: set THIS or ANTHROPIC_API_KEY. There is NO deterministic/template
# fallback — without a Claude provider, listening runs fail loudly (a keyword-echo plan and a
# templated brief are exactly the broken output we refuse to ship).
CLAUDE_CODE_OAUTH_TOKEN=
# Planning + synthesis model (worker). Default favors cost/quota efficiency; override to claude-opus-4-8.
LISTENING_SYNTH_MODEL=claude-sonnet-4-6

# ── OpenRouter — only needed for the manual "Deep run" (Perplexity deep research, ~$0.90/query) ──
# Scheduled daily runs do NOT use this. Leave blank unless you use Deep run.
OPENROUTER_API_KEY=

# ── Vercel ────────────────────────────
# Auto-set by Vercel. Set locally for development.
VERCEL_URL=https://your-app.vercel.app
# Secret to manually trigger /api/cron/listening. Vercel Cron is authed automatically
# via the x-vercel-cron header; this is only for manual curl/testing.
CRON_SECRET=generate-a-long-random-string

# ── Listening Worker (Railway) ────────
# Vercel calls this worker URL for last30days research runs and the daily cron.
LISTENING_WORKER_URL=https://your-listening-worker.up.railway.app
WORKER_SHARED_SECRET=generate-a-long-random-string
LISTENING_WORKER_NOTIFY_TIMEOUT_MS=25000     # manual "Search now" notify timeout (Vercel → worker)
# LISTENING_CRON_TIMEOUT_MS=15000             # optional: /api/cron/listening fetch timeout

# ── last30days engine (worker) ────────
# Retrieval runs free + heuristic across these sources; the planner LLM is skipped via --plan.
# Keep reasoning provider on "auto" — no paid LLM key is needed for scheduled runs.
LAST30DAYS_MEMORY_DIR=/data/last30days
LAST30DAYS_SOURCES=reddit,hackernews,youtube,github,polymarket,grounding
LAST30DAYS_TIMEOUT_SECONDS=900
LAST30DAYS_REASONING_PROVIDER=auto
LAST30DAYS_USE_STORE=false                    # persist engine findings to SQLite (off; we dedupe via listening_hits)

# ── Optional: ScrapeCreators (for TikTok, Instagram Reels, Threads) ──
# Get from: https://scrapecreators.com  (10K free calls/mo)
# When set, topics whose platform_focus includes tiktok/instagram/threads also pull those sources.
SCRAPECREATORS_API_KEY=
