# ──────────────────────────────────────
# ContentPlanner — Environment Variables
# ──────────────────────────────────────
# Copy this to .env and fill in your values.
# Never commit .env to git.

# ── Supabase ──────────────────────────
# Get from: https://app.supabase.com/project/<ref>/settings/api
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOi...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...       # Worker only (keep secret)

# ── Telegram ──────────────────────────
# Create bot via @BotFather on Telegram
# Set webhook: https://api.telegram.org/bot<TOKEN>/setWebhook?url=<YOUR_VERCEL_URL>/api/webhooks/tg
TELEGRAM_BOT_TOKEN=123456:ABC-DEF...

# ── Composio (Instagram) ──────────────
# Get from: https://app.composio.dev
COMPOSIO_API_KEY=

# ── Anthropic (AI enrichment + listening analysis) ──
# Get from: https://console.anthropic.com/keys
# Uses Claude Haiku — draws from your Claude subscription limits via Agent SDK billing
ANTHROPIC_API_KEY=sk-ant-...

# ── OpenRouter (AI enrichment, legacy) ────────
# Get from: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-...

# ── Vercel ────────────────────────────
# Auto-set by Vercel. Set locally for webhook development.
VERCEL_URL=https://your-app.vercel.app

# ── Listening Worker ──────────────────
# Optional: where last30days stores its files on the worker
LAST30DAYS_MEMORY_DIR=/data/last30days

# ── Optional: ScrapeCreators (for TikTok, Instagram Reels, Threads) ──
# Get from: https://scrapecreators.com
SCRAPECREATORS_API_KEY=

# ── Telegram Bot (secret for webhook validation) ─────────────────
# Generate a random string for this. Must match what you set in @BotFather.
TELEGRAM_BOT_SECRET=
